# Copy this file to .env and edit it to suit your needs.
DIARY_DIRPATH=~/diary/diary_entries
# Command to open the diary editor; leave empty to print the target path (entry file by default, or the entries folder if DIARY_EDITOR_TARGET=folder).
DIARY_EDITOR=
# The target for the diary editor. Can be either "file" or "folder".
DIARY_EDITOR_TARGET=file
